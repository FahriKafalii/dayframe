# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any depth — monorepo apps/packages each have their own)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js build output (any depth)
.next/
out/

# production build output
build/
dist/

# misc
.DS_Store
Thumbs.db
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / IDE
.vscode/
.idea/
*.swp
*.swo

# AI tooling / local agent state
.claude/
.cursor/
.aider*
