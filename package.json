{
  "name": "dayframe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" run dev",
    "dev:api": "pnpm --filter @dayframe/api dev",
    "dev:web": "pnpm --filter @dayframe/web dev",
    "dev:admin": "pnpm --filter @dayframe/admin dev",
    "build": "pnpm -r --filter \"./apps/*\" run build",
    "lint": "pnpm -r --filter \"./apps/*\" run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:migrate": "pnpm --filter @dayframe/db run db:migrate",
    "db:migrate:undo": "pnpm --filter @dayframe/db run db:migrate:undo",
    "db:migrate:undo:all": "pnpm --filter @dayframe/db run db:migrate:undo:all",
    "db:status": "pnpm --filter @dayframe/db run db:status"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
